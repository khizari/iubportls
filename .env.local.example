# Vercel Blob storage token
# Create a Blob store in your Vercel project dashboard (Storage tab),
# then Vercel will give you this automatically when you `vercel env pull`.
BLOB_READ_WRITE_TOKEN=

# Password for the admin panel (simple single-admin auth)
ADMIN_PASSWORD=change-me
# Random long string used to sign the admin session cookie
ADMIN_SESSION_SECRET=change-me-too-a-long-random-string
